scalar DateTime

type Todo {
  id: ID!
  title: String!
  description: String
  completed: Boolean!
  createdAt: DateTime!
  updatedAt: DateTime!
}

type Query {
  todos: [Todo!]!
  todo(id: ID!): Todo
}

type Mutation {
  createTodo(title: String!, description: String): Todo!
  updateTodo(
    id: ID!
    title: String
    description: String
    completed: Boolean
  ): Todo
  deleteTodo(id: ID!): Boolean!
}
